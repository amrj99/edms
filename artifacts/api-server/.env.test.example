# .env.test — Test environment configuration
# Copy this to .env.test and fill in values for local test runs.
# This file is loaded by src/test/setup.ts automatically.
#
# DO NOT commit .env.test — it may contain real DB credentials.
# This example file is safe to commit.

# Required: URL of the test database (separate from dev DB)
# Start it with: docker compose -f docker-compose.test.yml up -d
TEST_DATABASE_URL=postgresql://edms_test:edms_test_password@localhost:5433/edms_test

# JWT secret for test tokens — any string works, must be consistent within a run
JWT_SECRET=local-test-secret-replace-with-anything-long-enough

# Silence pino logs during tests — set to "debug" to see logs while debugging
LOG_LEVEL=silent
