{
  "name": "@workspace/api-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && node --enable-source-maps ./start.mjs",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./start.mjs",
    "start:prod": "NODE_ENV=production node --enable-source-maps ./dist/index.mjs",
    "seed": "node ./build.mjs && node --enable-source-maps ./dist/seed.mjs",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:migrate": "pnpm --filter @workspace/db run push",
    "db:seed": "pnpm run seed",
    "docker:build": "docker build -t edms-api .",
    "docker:start": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@types/nodemailer": "^7.0.11",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "openai": "^6.27.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.4",
    "pino": "^9",
    "pino-http": "^10"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
