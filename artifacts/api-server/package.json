{
  "name": "@workspace/api-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && node --enable-source-maps ./start.mjs",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./start.mjs",
    "start:prod": "NODE_ENV=production node --enable-source-maps ./dist/index.mjs",
    "seed": "node ./build.mjs && node --enable-source-maps ./dist/seed.mjs",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:migrate": "pnpm --filter @workspace/db run push",
    "db:seed": "pnpm run seed",
    "docker:build": "docker build -t edms-api .",
    "docker:start": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/s3-request-presigner": "^3.1020.0",
    "@elastic/elasticsearch": "^9.3.4",
    "@google-cloud/storage": "^7.19.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.6.1",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^7.0.11",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "openai": "^6.27.0",
    "pino": "^9",
    "pino-http": "^10",
    "resend": "^6.10.0",
    "socket.io": "^4.8.3",
    "@sentry/node": "^8",
    "stripe": "^22.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/pg": "^8.11.0",
    "pg": "^8.13.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/supertest": "^6.0.3",
    "dotenv": "^16.4.7",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "supertest": "^7.0.0",
    "thread-stream": "3.1.0",
    "vitest": "^3.2.4"
  }
}
