# ============================================================
# EDMS - Engineering Document Management System
# Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/edms

# ── Authentication ───────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-use-openssl-rand-base64-64
REFRESH_TOKEN_SECRET=change-me-use-openssl-rand-base64-64

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production
# Leave empty to allow all origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Frontend (Vite) ──────────────────────────────────────────
# URL of your API server (used by the frontend to make requests)
VITE_API_URL=https://api.yourdomain.com

# ── File Storage (future) ────────────────────────────────────
# STORAGE_CONFIG={"type":"local","path":"./uploads"}
# For S3: STORAGE_CONFIG={"type":"s3","bucket":"my-bucket","region":"us-east-1"}

# ── Search (future) ──────────────────────────────────────────
# ELASTICSEARCH_URL=http://localhost:9200

# ── Email (future) ───────────────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# EMAIL_FROM=noreply@yourdomain.com
