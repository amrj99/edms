# ============================================================
# EDMS - Engineering Document Management System
# Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables here are read by docker-compose.yml via env_file.
# Variables explicitly listed in the compose environment: block are
# also substituted at compose-file-parse time (${VAR:-default} syntax).
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Database ─────────────────────────────────────────────────
# Full PostgreSQL connection string.
# For Docker Compose (internal postgres service), use the service name:
#   DATABASE_URL=postgresql://edms:yourpassword@postgres:5432/edms
# For an external/managed database, use the full hostname.
# This value takes precedence over the docker-compose.yml fallback formula.
DATABASE_URL=postgresql://edms:edms_dev_password@postgres:5432/edms

# Internal postgres container password — must match DATABASE_URL above
POSTGRES_PASSWORD=edms_dev_password

# ── Authentication ───────────────────────────────────────────
# Generate strong secrets with: openssl rand -base64 64
JWT_SECRET=change-me-use-openssl-rand-base64-64
REFRESH_TOKEN_SECRET=change-me-use-openssl-rand-base64-64

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
# Leave empty to allow all origins (not recommended for production).
ALLOWED_ORIGINS=https://yourdomain.com

# ── App URL ──────────────────────────────────────────────────
# Used in outgoing email links. Set to your public HTTPS domain.
APP_URL=https://yourdomain.com

# ── AI (OpenRouter) ──────────────────────────────────────────
# Required for Document AI Analysis. Get a key at openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Email (Resend) ───────────────────────────────────────────
# Set RESEND_API_KEY — without it all emails are silently skipped.
# FROM_EMAIL must match a verified domain in your Resend dashboard.
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=ArcScale EDMS

# ── File Storage ─────────────────────────────────────────────
# Controls the default storage backend for new organizations.
# Overridable per-org via Admin → Storage settings.
#
# Options:
#   onpremise  — local disk inside the container (default, no extra config)
#   r2         — Cloudflare R2 (set CF_* and R2_* vars below)
#   s3         — AWS S3 or S3-compatible (set R2_* vars with S3 values)
DEFAULT_STORAGE_TYPE=onpremise

# Local upload path (used when DEFAULT_STORAGE_TYPE=onpremise)
DEFAULT_STORAGE_PATH=/app/uploads

# Maximum file upload size in MB (must match client_max_body_size in nginx.conf)
MAX_UPLOAD_SIZE_MB=1024

# ── Cloudflare R2 Storage ────────────────────────────────────
# Required when DEFAULT_STORAGE_TYPE=r2 or any org uses R2 storage.
# R2_ENDPOINT format: https://<account-id>.r2.cloudflarestorage.com
CF_ACCOUNT_ID=
CF_AI_TOKEN=
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=

# ── Ports (optional overrides) ───────────────────────────────
# Default: API on 8080, frontend on 80/443
# API_PORT=8080
# FRONTEND_PORT=80
# FRONTEND_HTTPS_PORT=443
